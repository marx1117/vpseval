<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none">
  <!-- 服务器主体：三层层叠的服务器 -->
  <rect x="4" y="5" width="18" height="6" rx="1.5" fill="#9FE870"/>
  <rect x="4" y="13" width="18" height="6" rx="1.5" fill="#9FE870"/>
  <rect x="4" y="21" width="18" height="6" rx="1.5" fill="#9FE870"/>
  
  <!-- 服务器面板细节：每层的小圆点和短线 -->
  <circle cx="7.5" cy="8" r="1" fill="#163300"/>
  <circle cx="7.5" cy="16" r="1" fill="#163300"/>
  <circle cx="7.5" cy="24" r="1" fill="#163300"/>
  <rect x="10" y="7.2" width="5" height="1.2" rx="0.6" fill="#163300" opacity="0.4"/>
  <rect x="10" y="15.2" width="5" height="1.2" rx="0.6" fill="#163300" opacity="0.4"/>
  <rect x="10" y="23.2" width="5" height="1.2" rx="0.6" fill="#163300" opacity="0.4"/>
  
  <!-- 验证勾选标记 -->
  <circle cx="24" cy="24" r="6" fill="#2e7314"/>
  <path d="M20.8 24L23.2 26.5L27.5 21.5" stroke="#9FE870" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
</svg>