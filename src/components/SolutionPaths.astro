---
import { solutionPaths } from '../lib/data';

const colorMap: Record<string, { bg: string; border: string; text: string; icon: string; darkBg: string; darkBorder: string; darkText: string }> = {
  green: {
    bg: 'bg-green-50', border: 'border-green-200', text: 'text-green-800', icon: 'text-green-600',
    darkBg: 'dark:bg-green-900/20', darkBorder: 'dark:border-green-800', darkText: 'dark:text-green-300',
  },
  blue: {
    bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-800', icon: 'text-blue-600',
    darkBg: 'dark:bg-blue-900/20', darkBorder: 'dark:border-blue-800', darkText: 'dark:text-blue-300',
  },
  purple: {
    bg: 'bg-purple-50', border: 'border-purple-200', text: 'text-purple-800', icon: 'text-purple-600',
    darkBg: 'dark:bg-purple-900/20', darkBorder: 'dark:border-purple-800', darkText: 'dark:text-purple-300',
  },
  orange: {
    bg: 'bg-orange-50', border: 'border-orange-200', text: 'text-orange-800', icon: 'text-orange-600',
    darkBg: 'dark:bg-orange-900/20', darkBorder: 'dark:border-orange-800', darkText: 'dark:text-orange-300',
  },
};

const icons: Record<string, string> = {
  green: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  blue: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  purple: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  orange: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z',
};
---

<section class="container-page py-12">
  <div class="text-center mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white">方案路径 · 四条路线</h2>
    <p class="text-base text-gray-500 dark:text-gray-400 mt-1">从零成本到完全自主，按你的情况选</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {solutionPaths.map((path) => {
      const c = colorMap[path.color] || colorMap.blue;
      return (
        <a
          href={`/compare?level=${path.level}`}
          class={`block p-5 rounded-xl border-2 ${c.bg} ${c.border} ${c.darkBg} ${c.darkBorder} hover:shadow-sm transition-shadow group`}
        >
          <div class="flex items-start gap-3">
            <svg class={`w-6 h-6 mt-0.5 ${c.icon} flex-shrink-0`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[path.color] || icons.blue} />
            </svg>
            <div>
              <h3 class={`font-semibold text-base ${c.text} ${c.darkText}`}>
                {path.title} · {path.subtitle}
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{path.description}</p>
              <div class="flex items-center gap-3 mt-2 text-sm text-gray-400">
                <span>{path.timeEstimate}</span>
                <span>{path.costEstimate}</span>
              </div>
            </div>
          </div>
        </a>
      );
    })}
  </div>
</section>
