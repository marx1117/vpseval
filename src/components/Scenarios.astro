---
const picks = [
  {
    tag: '追求速度',
    desc: 'CN2 GIA / 9929 精品线路，延迟最低',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    color: 'purple',
    providers: [
      { name: 'DMIT (LAX PVM.LAX.Pro)', spec: '1C 1G 20G', price: '$6.9/月', latency: '电信 142ms' },
      { name: 'V.PS (Tokyo Mini)', spec: '1C 1G 20G NVMe', price: '$5.99/月', latency: '电信 95ms' },
    ],
  },
  {
    tag: '追求性价比',
    desc: '日常代理和建站足够，价格友好',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    color: 'green',
    providers: [
      { name: 'RackNerd (LA DC02)', spec: '1C 1G 20G', price: '$2.50/月', latency: '电信 175ms' },
      { name: 'CloudCone (LA MC)', spec: '1C 1G 20G', price: '$2.99/月', latency: '电信 170ms' },
    ],
  },
  {
    tag: '大流量需求',
    desc: '不限流量或高带宽，适合下载/备份',
    icon: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4',
    color: 'orange',
    providers: [
      { name: 'BuyVM (LAS)', spec: '1C 1G 10G', price: '$2/月', latency: '不限流量' },
      { name: 'HostHatch (AMS)', spec: '1C 1G 15G NVMe', price: '$3/月', latency: '电信 165ms' },
    ],
  },
];

const colorMap: Record<string, { bg: string; border: string; text: string; dot: string }> = {
  purple: { bg: 'bg-purple-50 dark:bg-purple-900/20', border: 'border-purple-200 dark:border-purple-800', text: 'text-purple-700 dark:text-purple-300', dot: 'bg-purple-500' },
  green: { bg: 'bg-green-50 dark:bg-green-900/20', border: 'border-green-200 dark:border-green-800', text: 'text-green-700 dark:text-green-300', dot: 'bg-green-500' },
  orange: { bg: 'bg-orange-50 dark:bg-orange-900/20', border: 'border-orange-200 dark:border-orange-800', text: 'text-orange-700 dark:text-orange-300', dot: 'bg-orange-500' },
};
---

<section class="container-page py-12">
  <div class="text-center mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white">按需推荐</h2>
    <p class="text-base text-gray-500 dark:text-gray-400 mt-1">看重什么就选什么，客观数据说话</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    {picks.map(p => {
      const c = colorMap[p.color] || colorMap.green;
      return (
        <div class={`rounded-xl border ${c.border} ${c.bg} p-5`}>
          <div class="flex items-center gap-2 mb-3">
            <div class={`w-2 h-2 rounded-full ${c.dot}`}></div>
            <span class={`text-sm font-semibold ${c.text}`}>{p.tag}</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">{p.desc}</p>

          <div class="space-y-3">
            {p.providers.map(prov => (
              <a href="/compare" class="block p-3 rounded-lg bg-white/70 dark:bg-gray-800/70 border border-gray-100 dark:border-gray-700 hover:shadow-sm transition-shadow">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-medium text-gray-900 dark:text-white">{prov.name}</span>
                  <span class="text-sm font-mono font-medium text-brand-600 dark:text-brand-400">{prov.price}</span>
                </div>
                <div class="flex items-center justify-between text-xs text-gray-400">
                  <span>{prov.spec}</span>
                  <span>{prov.latency}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>
