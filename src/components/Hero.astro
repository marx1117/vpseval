---
const quickPrompts = [
  { text: '电信用户 预算$5 月付，推荐哪个 VPS？' },
  { text: '想搭个梯子，联通宽带，便宜点的方案' },
  { text: '做跨境电商独立站，需要稳定线路' },
  { text: '新买的 VPS 第一步该做什么？' },
];
---

<section class="container-page pt-16 sm:pt-24 pb-10">
  <div class="max-w-2xl mx-auto text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight leading-[1.1]">
      选 VPS，直接 <span class="text-brand-400">问 AI</span>
    </h1>
    <p class="text-lg sm:text-xl lg:text-2xl text-gray-500 dark:text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed">
      告诉 AI 你的需求和预算，从实测数据里匹配最合适的方案
    </p>
  </div>

  <!-- AI Dialog -->
  <div id="ai-dialog" class="card overflow-hidden text-left">
      <div class="px-5 py-3.5 border-b border-gray-100 dark:border-gray-800 flex items-center gap-2 bg-gray-50/50 dark:bg-gray-800/30">
        <div class="flex items-center gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full bg-red-400/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-green-400/60"></span>
        </div>
        <span class="text-xs text-gray-400 ml-2">AI 助手</span>
      </div>
      <div class="p-5 sm:p-6">
        <div id="prompt-list">
          <div class="flex items-start gap-3 mb-5">
            <div class="w-9 h-9 rounded-full bg-brand-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm text-gray-600 dark:text-gray-300 mb-3">直接问我，比如：</p>
              <div class="space-y-2">
                {quickPrompts.map((prompt, idx) => (
                  <button class="quick-prompt w-full text-left px-4 py-3 rounded-xl border border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30 text-sm text-gray-600 dark:text-gray-300 hover:border-brand-200 dark:hover:border-brand-800 hover:bg-brand-50/30 dark:hover:bg-brand-900/10 transition-all" data-query={prompt.text}>
                    <span class="text-gray-400 mr-2 text-xs">{idx + 1}</span>
                    {prompt.text}
                  </button>
                ))}
              </div>
            </div>
          </div>
          <div class="flex gap-2">
            <input
              type="text"
              id="ai-input"
              placeholder="输入问题，如：移动宽带 ¥5/月 选什么 VPS..."
              class="flex-1 px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none"
            />
            <button id="ai-send" class="btn-primary flex-shrink-0">
              提问
            </button>
          </div>
        </div>
        <div id="ai-result" class="hidden"></div>
      </div>
    </div>
</section>

<script>
  (function() {
    const input = document.getElementById('ai-input');
    const sendBtn = document.getElementById('ai-send');
    const promptList = document.getElementById('prompt-list');
    const resultArea = document.getElementById('ai-result');
    let loading = false;

    async function askAI(query) {
      if (loading || !query.trim()) return;
      loading = true;
      promptList.classList.add('hidden');
      resultArea.classList.remove('hidden');
      resultArea.innerHTML = `<div class="flex items-center gap-3 py-10 justify-center text-sm text-gray-400">
        <svg class="animate-spin w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
        AI 推理中...
      </div>`;
      try {
        const res = await fetch(`http://localhost:4399/api/chat?q=${encodeURIComponent(query)}`);
        const data = await res.json();
        if (data.error) {
          resultArea.innerHTML = `<div class="text-sm text-red-500 p-4 rounded-2xl bg-red-50 dark:bg-red-900/20">${data.error}</div><button id="retry-btn" class="mt-3 text-sm text-brand-600 hover:underline font-medium">← 重新提问</button>`;
          document.getElementById('retry-btn')?.addEventListener('click', resetDialog);
        } else {
          resultArea.innerHTML = data.html + `<div class="mt-4 flex gap-3"><button id="retry-btn" class="text-sm text-brand-600 hover:underline font-medium">重新提问</button><a href="/compare" class="text-sm text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 font-medium">去对比页看看 →</a></div>`;
          document.getElementById('retry-btn')?.addEventListener('click', resetDialog);
        }
      } catch {
        resultArea.innerHTML = `<div class="text-sm text-gray-500 p-4 rounded-2xl bg-gray-50 dark:bg-gray-900">AI 服务未启动。终端运行 <code class="text-brand-600 font-medium">node server.mjs</code></div><button id="retry-btn" class="mt-3 text-sm text-brand-600 hover:underline font-medium">← 重新提问</button>`;
        document.getElementById('retry-btn')?.addEventListener('click', resetDialog);
      }
      loading = false;
    }

    function resetDialog() { promptList.classList.remove('hidden'); resultArea.classList.add('hidden'); resultArea.innerHTML = ''; input.value = ''; loading = false; }

    sendBtn.addEventListener('click', () => askAI(input.value));
    input.addEventListener('keydown', e => { if (e.key === 'Enter') askAI(input.value); });
    document.querySelectorAll('.quick-prompt').forEach(btn => { btn.addEventListener('click', function() { askAI(this.dataset.query); }); });
  })();
</script>
