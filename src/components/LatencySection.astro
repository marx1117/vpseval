---
import { providers, bestLatency } from '../lib/data';

const displayProviders = providers.slice(0, 6);

const ispLabels = [
  { key: 'telecom', label: '电信', color: 'bg-blue-500' },
  { key: 'unicom', label: '联通', color: 'bg-red-500' },
  { key: 'mobile', label: '移动', color: 'bg-green-500' },
];
---

<section class="container-page py-12">
  <div class="text-center mb-8">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white">三网延迟实测</h2>
    <p class="text-base text-gray-500 dark:text-gray-400 mt-1">晚高峰 21:00 节点到中国大陆各运营商平均延迟，单位 ms</p>
  </div>

  <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
          <th class="py-3 px-4 text-sm font-medium text-gray-500 dark:text-gray-400 sticky left-0 bg-gray-50 dark:bg-gray-800 z-10">服务商</th>
          <th class="py-3 px-3 text-sm font-medium text-gray-500 dark:text-gray-400">节点</th>
          <th class="py-3 px-3 text-sm font-medium text-gray-500 dark:text-gray-400">月付</th>
          {ispLabels.map(isp => (
            <th class="py-3 px-3 text-sm font-medium text-gray-500 dark:text-gray-400">
              <span class={`inline-block w-2 h-2 rounded-full ${isp.color} mr-1 align-middle`}></span>
              {isp.label}
            </th>
          ))}
          <th class="py-3 px-3 text-sm font-medium text-gray-500 dark:text-gray-400 w-16"></th>
        </tr>
      </thead>
      <tbody>
        {displayProviders.map(p => {
          const nodeKeys = Object.keys(p.latency);
          const bestNode = nodeKeys[0];
          const firstNodeCN = p.locationsCN[p.locations.indexOf(bestNode)] || p.locationsCN[0];
          return (
          <tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors group">
            <td class="py-3 px-4 sticky left-0 bg-white dark:bg-gray-950 group-hover:bg-gray-50 dark:group-hover:bg-gray-900/50 z-10">
              <span class="text-sm font-medium text-gray-900 dark:text-white">{p.name}</span>
            </td>
            <td class="py-3 px-3">
              <span class={`text-sm ${nodeKeys.length > 1 ? 'text-brand-600 dark:text-brand-400 underline decoration-dotted underline-offset-2 cursor-help font-medium' : 'text-gray-500 dark:text-gray-400'}`}>
                {firstNodeCN}
                {nodeKeys.length > 1 && <span class="text-xs text-gray-400 ml-0.5">+{nodeKeys.length - 1}</span>}
              </span>
            </td>
            <td class="py-3 px-3 text-sm font-mono font-medium text-gray-900 dark:text-white">${p.priceFrom}/月</td>
            {ispLabels.map(isp => {
              const val = bestLatency(p)[isp.key as 'telecom' | 'unicom' | 'mobile'];
              let barColor = 'bg-green-500';
              if (val > 120) barColor = 'bg-yellow-500';
              if (val > 160) barColor = 'bg-orange-500';
              if (val > 200) barColor = 'bg-red-500';
              const barWidth = Math.min(100, val / 2);
              return (
                <td class="py-3 px-3">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-mono text-gray-700 dark:text-gray-300 w-10 text-right">{val}</span>
                    <div class="flex-1 h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
                      <div class={`h-full rounded-full ${barColor}`} style={`width:${barWidth}%`}></div>
                    </div>
                  </div>
                </td>
              );
            })}
            <td class="py-3 px-3">
              <a href={`/go/${p.goSlug || p.id}`} target="_blank" rel="nofollow noopener" class="text-sm text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium">官网</a>
            </td>
          </tr>
        )})}
      </tbody>
    </table>
  </div>

  <div class="text-center mt-3">
    <a href="/compare" class="inline-flex items-center gap-1 text-sm text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium">
      查看全部 {providers.length} 家
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <p class="text-center text-xs text-gray-400 mt-3">数据来源: ITDog 全球 Ping 节点 · 更新于 2026.06 · 延迟越低越好</p>
</section>
