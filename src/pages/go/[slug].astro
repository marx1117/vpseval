---
import { AFFILIATE_REDIRECTS } from '../../lib/data.ts';

export function getStaticPaths() {
  return Object.keys(AFFILIATE_REDIRECTS).map(slug => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const targetUrl = AFFILIATE_REDIRECTS[slug as string];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="refresh" content={`0;url=${targetUrl}`}>
  <link rel="canonical" href={targetUrl}>
  <title>Redirecting...</title>
</head>
<body>
  <p>Redirecting to <a href={targetUrl}>{targetUrl}</a>...</p>
</body>
</html>
