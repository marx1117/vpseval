            <span class="absolute bottom-1.5 left-0 w-full h-3 bg-brand-200/70 dark:bg-brand-700/40 -z-0 rounded"></span>
          </span>
        </h1>

        <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 leading-relaxed mb-8 mx-auto">
        18 家服务商真实数据，按三网延迟、线路类型、性价比整理。<br class="hidden sm:block"/>
          告诉 AI 你的需求，10 秒给出推荐方案。
        </p>

        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/compare" class="btn-primary">
            选购指南
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a href="#ai-section" class="btn-secondary">
            问机鉴 AI
          </a>
        </div>

          <!-- 数据栏 -->
        <div class="grid grid-cols-4 gap-3 mt-10 pt-8 border-t border-gray-100 dark:border-gray-800">
          {stats.map(s => (
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white tabular-nums">{s.num}</div>
              <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== 场景导航 ========== -->
  <section class="container-page py-12 sm:py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-2">按场景选</h2>
