    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      {scenarios.slice(0, 6).map(s => {
        const colorMap: any = {
          proxy: 'from-brand-100 to-brand-50 dark:from-brand-900/30 dark:to-brand-900/10 text-brand-700 dark:text-brand-300',
          hosting: 'from-blue-100 to-blue-50 dark:from-blue-900/30 dark:to-blue-900/10 text-blue-700 dark:text-blue-300',
          dev: 'from-purple-100 to-purple-50 dark:from-purple-900/30 dark:to-purple-900/10 text-purple-700 dark:text-purple-300',
          gaming: 'from-orange-100 to-orange-50 dark:from-orange-900/30 dark:to-orange-900/10 text-orange-700 dark:text-orange-300',
          pt: 'from-pink-100 to-pink-50 dark:from-pink-900/30 dark:to-pink-900/10 text-pink-700 dark:text-pink-300',
          learning: 'from-cyan-100 to-cyan-50 dark:from-cyan-900/30 dark:to-cyan-900/10 text-cyan-700 dark:text-cyan-300',
