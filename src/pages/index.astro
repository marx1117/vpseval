  <!-- ========== 底部 CTA ========== -->
  <section class="container-page py-12 sm:py-16">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-gray-900 to-gray-800 dark:from-gray-900 dark:to-black p-10 sm:p-14 text-center">
      <div class="absolute top-0 right-0 w-64 h-64 bg-brand-500/20 rounded-full blur-3xl -mr-20 -mt-20"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-brand-400/10 rounded-full blur-3xl -ml-10 -mb-10"></div>
      <div class="relative">
        <h2 class="text-2xl sm:text-4xl font-extrabold text-white mb-3 tracking-tight">还在犹豫？先去对比页看看</h2>
        <p class="text-gray-400 mb-7 max-w-xl mx-auto">18 家服务商 · 12 列数据 · 三网延迟一眼看清</p>
        <a href="/compare" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-brand-400 hover:bg-brand-500 text-gray-900 font-bold transition-colors">
          打开选购指南
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
