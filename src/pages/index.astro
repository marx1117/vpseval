  <div class="py-6"></div>
</BaseLayout>

<script>
  (function() {
    function setupAI(inputId, sendId, resultId) {
      const input = document.getElementById(inputId);
      const sendBtn = document.getElementById(sendId);
      const resultArea = document.getElementById(resultId);
      if (!input || !sendBtn || !resultArea) return;

      let loading = false;

      async function askAI(query) {
        if (loading || !query.trim()) return;
        loading = true;
        // 隐藏提问区，显示回答区
        const promptArea = resultArea.parentElement?.querySelector('.ai-prompt-area');
        if (promptArea) (promptArea as HTMLElement).style.display = 'none';
        resultArea.classList.remove('hidden');
        resultArea.innerHTML = `<div class="flex items-center gap-3 py-8 justify-center text-sm text-gray-400">
          <svg class="animate-spin w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
          正在思考中...
        </div>`;
        try {
          const isLocal = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
          const apiUrl = isLocal ? 'https://vpseval.com/api/chat' : '/api/chat';
          const res = await fetch(`${apiUrl}?q=${encodeURIComponent(query)}`);
          const data = await res.json();
          if (data.error) {
            resultArea.innerHTML = `<div class="text-sm text-red-500 p-4 rounded-2xl bg-red-50 dark:bg-red-900/20">${data.error}</div><button class="ai-retry mt-3 text-sm text-brand-600 hover:underline font-medium">← 重新提问</button>`;
          } else {
            resultArea.innerHTML = data.html + `<div class="mt-4 flex gap-4"><button class="ai-retry text-sm text-brand-600 hover:underline font-medium">重新提问</button><a href="/compare" class="text-sm text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 font-medium">去对比页看看 →</a></div>`;
          }
        } catch {
          resultArea.innerHTML = `<div class="text-sm text-gray-500 p-4 rounded-2xl bg-gray-50 dark:bg-gray-900">AI 服务暂时不可用，请稍后再试</div><button class="ai-retry mt-3 text-sm text-brand-600 hover:underline font-medium">← 重新提问</button>`;
        }
        loading = false;
        // 重新绑定重试按钮
        resultArea.querySelectorAll('.ai-retry').forEach(btn => {
          btn.addEventListener('click', () => {
            resultArea.classList.add('hidden');
            resultArea.innerHTML = '';
            const pa = resultArea.parentElement?.querySelector('.ai-prompt-area');
            if (pa) (pa as HTMLElement).style.display = '';
            input.value = '';
          });
        });
      }

      sendBtn.addEventListener('click', () => askAI(input.value));
      input.addEventListener('keydown', e => { if (e.key === 'Enter') askAI(input.value); });
    }

    // AI 对话框
    setupAI('ai-input-main', 'ai-send-main', 'ai-result-main');

    // quick prompt 按钮：填入主对话框并发送
    document.querySelectorAll('.quick-prompt').forEach(btn => {
      btn.addEventListener('click', function() {
        const query = this.dataset.query;
        const mainInput = document.getElementById('ai-input-main');
        if (mainInput) {
          mainInput.value = query;
          mainInput.focus();
        }
        // 滚动到 AI 区
        document.getElementById('ai-section')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        // 触发主对话框的发送
        setTimeout(() => {
          document.getElementById('ai-send-main')?.click();
        }, 600);
      });
    });
  })();
</script>
