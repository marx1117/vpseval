---
import BaseLayout from '../layouts/BaseLayout.astro';
import { scenarios, solutionPaths, providers } from '../lib/data.ts';
import { knowledgeBase } from '../lib/knowledge.ts';

// 精选服务商标识（从 data.ts 拉取真实数据）
const featuredProviderIds = ['dmit', 'racknerd', 'cloudcone', 'bandwagon', 'hosthatch', 'buyvm'];
const featuredProviders = providers.filter(p => featuredProviderIds.includes(p.id)).slice(0, 6);

// 知识速查精选
const featuredKnowledge = knowledgeBase.slice(0, 8);

// 真实统计
const stats = [
  { num: '18', label: '家服务商', sub: '精选实测' },
  { num: '64', label: '篇知识库', sub: '持续更新' },
  { num: '24', label: '个一键脚本', sub: '开箱即用' },
  { num: '13', label: '个知识分类', sub: '系统梳理' },
];

// 快速提问模板
const quickPrompts = [
  '电信用户 ¥5/月 推荐哪个 VPS？',
  '联通宽带 自建代理 怎么搞',
  '做独立站需要什么配置？',
  '新买 VPS 第一步该做什么？',
];

// 场景图标
const scenarioIcons: any = {
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  globe: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  terminal: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  zap: 'M13 10V3L4 14h7v7l9-11h-7z',
  download: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4',
  book: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
};

// 延迟颜色
function latencyColor(ms: number): string {
  if (ms < 50) return 'text-brand-600';
  if (ms < 120) return 'text-yellow-600';
  if (ms < 200) return 'text-orange-600';
  return 'text-red-500';
}

function bestLatency(p: typeof providers[number]): { telecom: number; unicom: number; mobile: number } {
  let best = { telecom: 999, unicom: 999, mobile: 999 };
  for (const l of Object.values(p.latency)) {
    if (l.telecom < best.telecom) best.telecom = l.telecom;
    if (l.unicom < best.unicom) best.unicom = l.unicom;
    if (l.mobile < best.mobile) best.mobile = l.mobile;
  }
  return best;
}
---

<BaseLayout title="机鉴 - VPS 选型与知识库" description="18 家精选 VPS 服务商，三网延迟实测数据，按线路、价格、用途智能推荐方案。">
  <!-- ========== Hero ========== -->
  <section class="relative overflow-hidden">
    <!-- 背景光斑 -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-[480px] h-[480px] bg-brand-200/40 dark:bg-brand-500/10 rounded-full blur-3xl"></div>
      <div class="absolute top-40 right-0 w-[360px] h-[360px] bg-brand-100/50 dark:bg-brand-700/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container-page pt-12 sm:pt-16 pb-20">
      <div class="max-w-2xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 dark:bg-brand-900/30 border border-brand-100 dark:border-brand-800/50 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
          <span class="text-xs font-medium text-brand-700 dark:text-brand-300">18 家精选服务商数据</span>
        </div>

