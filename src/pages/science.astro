---
import BaseLayout from '../layouts/BaseLayout.astro';

const scripts = [
  {
    name: 'Sing-box 全家桶',
    level: '入门',
    time: '3 min',
    bestFor: '新手首选 · 抗封锁优先',
    desc: 'VLESS+Reality / Hysteria2 / TUIC 一键部署，自动申请 TLS 证书，支持 Warp 原生 IP 分流',
    cmd: 'bash <(curl -fsSL https://raw.githubusercontent.com/marx1117/vpseval/main/scripts/singbox-install.sh)',
    tags: ['推荐', 'Sing-box', '全协议'],
    features: ['VLESS+Reality', 'Hysteria2', 'TUIC', '自动证书', 'Warp分流'],
  },
  {
    name: 'Hysteria2 极速',
    level: '入门',
    time: '2 min',
    bestFor: '极致速度 · 无需域名',
    desc: '基于 QUIC/UDP 协议，自签名证书无需域名，高丢包环境仍有极快速度',
    cmd: 'bash <(curl -fsSL https://raw.githubusercontent.com/marx1117/vpseval/main/scripts/hy2-install.sh)',
    tags: ['UDP', '无需域名', '极速'],
    features: ['自签名证书', 'QUIC协议', '暴力发包', '无需域名'],
  },
  {
    name: 'Xray 手动配置',
    level: '进阶',
    time: '5 min',
    bestFor: '抗封锁 · 配置透明',
    desc: 'VLESS + REALITY 手动安装部署，自动生成 UUID 和 x25519 密钥，配置透明可审计',
    cmd: 'bash <(curl -fsSL https://raw.githubusercontent.com/marx1117/vpseval/main/scripts/xray-install.sh)',
    tags: ['Xray', 'REALITY', '手动'],
    features: ['随机UUID', 'x25519密钥', 'REALITY伪装', '配置透明'],
  },
  {
    name: '3X-UI 面板',
    level: '入门',
    time: '3 min',
    bestFor: '多人共享 · 可视化管理',
    desc: 'Xray 内核 Web 管理面板，可视化多用户管理，内置流量统计和二维码一键分享',
    cmd: 'bash <(curl -fsSL https://raw.githubusercontent.com/marx1117/vpseval/main/scripts/3xui-install.sh)',
    tags: ['面板', '多用户', 'Xray'],
    features: ['Web面板', '多用户', '流量统计', '二维码分享'],
  },
  {
    name: 'Cloudflare WARP',
    level: '进阶',
    time: '4 min',
    bestFor: 'IPv6 纯栈 · 双栈分流',
    desc: '安装和管理 Cloudflare WARP，支持代理和全局模式切换，自动保护 SSH 不受影响',
    cmd: 'bash <(curl -fsSL https://raw.githubusercontent.com/marx1117/vpseval/main/scripts/warp-install.sh)',
    tags: ['WARP', '双栈', '分流'],
    features: ['代理/全局切换', 'SSH保护', 'IPv4/IPv6', 'WireGuard模式'],
  },
];

const protocols = [
  { name: 'VLESS+Reality', speed: '★★★★', security: '★★★★★', block: '极难', best: '个人自用首选' },
  { name: 'VLESS+XTLS', speed: '★★★★★', security: '★★★★', block: '较难', best: '速度优先,有一定经验' },
  { name: 'Trojan', speed: '★★★★', security: '★★★', block: '中等', best: '简单稳定,不追求极致' },
  { name: 'Hysteria2', speed: '★★★★★+', security: '★★★', block: '中等', best: '高延迟跨国,极速需求' },
  { name: 'Shadowsocks', speed: '★★★★', security: '★★', block: '极易', best: '低风险地区或中转转发' },
  { name: 'VMess+WS+TLS', speed: '★★★', security: '★★★', block: '较易', best: '适合套 CDN 伪装' },
];
---

<BaseLayout title="科学上网指南 - 机鉴" description="VPS 代理协议速查、服务端方案、客户端配置、注意事项。自建代理节点一站式参考。">
  <div class="container-page pt-16 sm:pt-24 pb-10">

    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-10">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight leading-[1.1]">科学上网</h1>
      <p class="text-lg sm:text-xl lg:text-2xl text-gray-500 dark:text-gray-300">精选开源代理脚本，一键部署。所有脚本可审计源码。</p>
    </div>

    <!-- Disclaimer -->
    <div class="mb-8 p-4 rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
        <div>
          <p class="text-sm font-medium text-amber-800 dark:text-amber-300">技术教程向</p>
          <p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5">本站仅提供开源脚本推荐和部署教程，不提供任何代理配置或节点服务。请遵守当地法律法规使用。</p>
        </div>
      </div>
    </div>

    <!-- ====== 1. 协议速查 ====== -->
    <div class="border-l-4 border-brand-400 dark:border-brand-600 pl-4 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-1">协议速查</h2>
      <p class="text-base text-gray-500 dark:text-gray-300">六种主流协议的速度、安全、抗封锁能力一览</p>
    </div>

    <div class="overflow-x-auto border border-gray-200 dark:border-gray-700 rounded-xl mb-12">
      <table class="w-full text-xs">
        <thead>
          <tr class="bg-gray-50 dark:bg-gray-800/50">
            <th class="text-left px-4 py-2.5 font-medium text-gray-700 dark:text-gray-300">协议</th>
            <th class="text-left px-4 py-2.5 font-medium text-gray-700 dark:text-gray-300">速度</th>
            <th class="text-left px-4 py-2.5 font-medium text-gray-700 dark:text-gray-300">安全性</th>
            <th class="text-left px-4 py-2.5 font-medium text-gray-700 dark:text-gray-300">抗封锁</th>
            <th class="text-left px-4 py-2.5 font-medium text-gray-700 dark:text-gray-300">最适合</th>
          </tr>
        </thead>
        <tbody>
          {protocols.map((p, i) => (
            <tr class={i % 2 === 0 ? 'bg-white dark:bg-gray-900' : 'bg-gray-50/50 dark:bg-gray-800/30'}>
              <td class="px-4 py-2.5 font-medium text-gray-800 dark:text-gray-200">{p.name}</td>
              <td class="px-4 py-2.5 text-gray-600 dark:text-gray-300">{p.speed}</td>
              <td class="px-4 py-2.5 text-gray-600 dark:text-gray-300">{p.security}</td>
              <td class="px-4 py-2.5 text-gray-600 dark:text-gray-300">{p.block}</td>
              <td class="px-4 py-2.5 text-gray-600 dark:text-gray-300">{p.best}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- ====== 2. 服务端方案 ====== -->
    <div class="border-l-4 border-brand-400 dark:border-brand-600 pl-4 mb-6">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-1">服务端方案</h2>
      <p class="text-base text-gray-500 dark:text-gray-300">SSH 连上 VPS 后粘贴执行，<strong>建议先在干净系统上运行</strong></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-12">
      {scripts.map(s => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-4 group">
          <div class="flex items-center justify-between gap-2 mb-2">
            <div class="flex items-center gap-1.5">
              <span class="text-xs px-1.5 py-0.5 rounded-full bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300">{s.level}</span>
              {s.tags.map(tag => (
                <span class="text-xs px-1.5 py-0.5 rounded-full bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400">{tag}</span>
              ))}
            </div>
            <span class="text-xs text-gray-400 dark:text-gray-300 flex-shrink-0">{s.time}</span>
          </div>
          <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-2">{s.name}</h3>
          <p class="text-xs text-gray-400 dark:text-gray-300 mb-3 leading-relaxed">{s.desc}</p>
          <div class="relative">
            <pre class="text-xs font-mono bg-gray-900 text-green-400 p-2 pr-8 rounded-lg overflow-x-auto whitespace-pre-wrap break-all leading-relaxed">{s.cmd}</pre>
            <button
              class="copy-btn absolute top-2 right-2 p-1.5 rounded bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white transition-colors"
              data-cmd={s.cmd} title="复制命令">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- ====== 3. 客户端方案 ====== -->
    <div class="border-l-4 border-brand-400 dark:border-brand-600 pl-4 mb-6 mt-10">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-1">客户端方案</h2>
      <p class="text-base text-gray-500 dark:text-gray-300">服务端部署完成后，用这些客户端连接</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { platform: 'Windows', apps: [
          { name: 'v2rayN', url: 'https://github.com/2dust/v2rayN/releases' },
          { name: 'Clash Verge', url: 'https://github.com/clash-verge-rev/clash-verge-rev/releases' },
          { name: 'Nekoray', url: 'https://github.com/MatsuriDayo/nekoray/releases' },
        ]},
        { platform: 'macOS', apps: [
          { name: 'Clash Verge', url: 'https://github.com/clash-verge-rev/clash-verge-rev/releases' },
          { name: 'V2RayU', url: 'https://github.com/yanue/V2rayU/releases' },
          { name: 'Nekoray', url: 'https://github.com/MatsuriDayo/nekoray/releases' },
        ]},
        { platform: 'Linux', apps: [
          { name: 'Clash Verge', url: 'https://github.com/clash-verge-rev/clash-verge-rev/releases' },
          { name: 'Nekoray', url: 'https://github.com/MatsuriDayo/nekoray/releases' },
          { name: 'v2rayA', url: 'https://github.com/v2rayA/v2rayA/releases' },
        ]},
        { platform: 'iOS', apps: [
          { name: 'Shadowrocket', url: 'https://apps.apple.com/app/shadowrocket/id932747118' },
          { name: 'Stash', url: 'https://apps.apple.com/app/stash/id1596063349' },
          { name: 'Quantumult X', url: 'https://apps.apple.com/app/quantumult-x/id1443988620' },
        ]},
        { platform: 'Android', apps: [
          { name: 'v2rayNG', url: 'https://github.com/2dust/v2rayNG/releases' },
          { name: 'Clash Meta', url: 'https://github.com/MetaCubeX/ClashMetaForAndroid/releases' },
          { name: 'Nekobox', url: 'https://github.com/MatsuriDayo/NekoBoxForAndroid/releases' },
        ]},
        { platform: '路由器', apps: [
          { name: 'OpenClash', url: 'https://github.com/vernesong/OpenClash' },
          { name: 'PassWall', url: 'https://github.com/xiaorouji/openwrt-passwall' },
          { name: 'SSR-Plus', url: 'https://github.com/fw876/helloworld' },
        ]},
      ].map(row => (
        <div class="rounded-xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 p-4 flex flex-col">
          <div class="flex flex-wrap gap-1 mb-2">
            {row.apps.map(app => (
              <span class="text-xs px-1.5 py-0.5 rounded-full bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400">{app.name}</span>
            ))}
          </div>
          <h3 class="text-sm font-medium text-gray-900 dark:text-white mb-2">{row.platform}</h3>
          <div class="space-y-2 mt-auto">
            {row.apps.map(app => (
              <div class="relative">
                <pre class="text-xs font-mono bg-gray-900 text-green-400 p-1.5 pr-10 rounded-lg overflow-x-auto whitespace-pre-wrap break-all leading-relaxed">{app.url}</pre>
                <a href={app.url} target="_blank" rel="noopener" class="absolute top-1 right-1 p-1 rounded bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white transition-colors" title="打开">
                  <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- ====== 4. 注意事项 ====== -->
    <div class="border-l-4 border-brand-400 dark:border-brand-600 pl-4 mb-6 mt-10">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-1">注意事项</h2>
    </div>
    <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 p-5 space-y-3 text-sm text-gray-600 dark:text-gray-300">
      <p><strong>先检测后部署：</strong>拿到新 VPS 先跑 <a href="/knowledge/vps-benchmark" class="text-brand-600 hover:underline">YABS 跑分 + 回程路由</a>，确认线路质量再部署服务。发现问题还能申请退款。</p>
      <p><strong>晚高峰复测：</strong>网络测试务必在 20:00-23:00 晚高峰重复一次，白天的数据参考价值有限。</p>
      <p><strong>SSH 防断连：</strong>部分脚本运行时间较长，建议在 screen 或 tmux 会话中执行，避免 SSH 断开导致部署中断。</p>
      <p><strong>核实脚本来源：</strong>所有脚本均可审计源码。不要从 Telegram 群、不明网站获取未知脚本。</p>
      <p><strong>合规使用：</strong>代理工具仅限合法用途（访问学术资源、远程办公、跨境业务等），请遵守当地法律法规。</p>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const cmd = btn.dataset.cmd || '';
      try {
        await navigator.clipboard.writeText(cmd);
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
        setTimeout(() => {
          btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
        }, 1500);
      } catch {
        // fallback silently
      }
    });
  });
</script>
